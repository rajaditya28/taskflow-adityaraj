# PostgreSQL
DB_USER=taskflow
DB_PASSWORD=taskflow_secret
DB_NAME=taskflow
DB_HOST=postgres
DB_PORT=5432

# JWT — change this to a random 32+ character string in production
JWT_SECRET=change_me_to_a_long_random_secret_string

# CORS origin for the frontend (used by backend to set Access-Control-Allow-Origin)
CORS_ORIGIN=http://localhost:3000
